{
  "description": "Gesture-based confirmation hook — opens a native camera window for hand gesture approval/denial",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit|WebFetch|WebSearch|Skill|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/gesture-hook.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "ExitPlanMode|AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/gesture-hook.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
