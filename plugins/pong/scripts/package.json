{
  "name": "pong-scripts",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "mkdir -p /tmp/pong-swift-cache && swiftc -module-cache-path /tmp/pong-swift-cache -O native/glimpse.swift -o native/glimpse -Xlinker -sectcreate -Xlinker __TEXT -Xlinker __info_plist -Xlinker native/Info.plist",
    "postinstall": "npm run build"
  }
}
